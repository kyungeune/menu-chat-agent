# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.*
*/.env
*/.env.*

# Jupyter / IPython
.ipynb_checkpoints/

# macOS
.DS_Store

# Logs
*.log
logs/

# SQLite / local DB
*.sqlite3
*.db

# Vector DB / embedding storage
chroma_db/
*/chroma_db/

# Build / distribution
build/
dist/
*.egg-info/

# IDE / Editor
.vscode/
.idea/

