.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Streamlit
.streamlit/secrets.toml

# Node (혹시 프론트 확장 시 대비)
node_modules/

# Uploaded / generated files
uploads/
temp/
tmp/
*.tmp

